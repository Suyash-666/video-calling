# Supabase project credentials. Get these from:
#   Supabase Dashboard -> Project Settings -> API
#
# The VITE_ prefix is required so Vite exposes them to the client bundle.
# The ANON key is safe to ship to browsers; it is gated by Supabase RLS.
#
# For production (Vercel):
#   Add the same two keys as Project Settings -> Environment Variables
#   in the Vercel dashboard. Names must match exactly (VITE_SUPABASE_URL
#   and VITE_SUPABASE_ANON_KEY) because Vite exposes only vars with
#   that prefix to the client bundle.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
